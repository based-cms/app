# =============================================================================
# CONVEX
# Dashboard: https://dashboard.convex.dev
# =============================================================================

# Your Convex deployment URL — looks like: https://happy-animal-123.convex.cloud
NEXT_PUBLIC_CONVEX_URL=https://happy-animal-123.eu-west-1.convex.cloud

# Your deployment slug — looks like: happy-animal-123
# Find it in: Dashboard → your project → Settings → URL & Deploy Key
CONVEX_DEPLOYMENT=dev:happy-animal-123 # team: d0dge, project: based-cms


# =============================================================================
# BETTER AUTH
# =============================================================================

# Public-facing URL of the app (used for OAuth callbacks, CSRF origin validation)
# REQUIRED — auth will fail if missing in production
SITE_URL=http://localhost:3000

# =============================================================================
# CLOUDFLARE R2
# These go into the CONVEX dashboard, not here — but list them so you have them handy.
# Dashboard: https://dash.cloudflare.com → R2 Object Storage
#
# In Convex dashboard → your project → Settings → Environment Variables, add:
#   R2_TOKEN            — Cloudflare API token with R2 read+write permissions
#   R2_ACCESS_KEY_ID    — R2 access key ID (generated under Manage R2 API Tokens)
#   R2_SECRET_ACCESS_KEY — R2 secret access key (same place)
#   R2_ENDPOINT         — https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#   R2_BUCKET           — bucket name, e.g. based-cms-media
# =============================================================================


# =============================================================================
# POLAR (deferred — fill in when billing UI is built in a future phase)
# Dashboard: https://dashboard.polar.sh
#
# In Convex dashboard → Environment Variables, add when ready:
#   POLAR_ACCESS_TOKEN   — from Polar dashboard → Settings → API Keys
#   POLAR_WEBHOOK_SECRET — generated when you register the webhook endpoint
# =============================================================================

NEXT_PUBLIC_CONVEX_SITE_URL=https://happy-animal-123.eu-west-1.convex.site
